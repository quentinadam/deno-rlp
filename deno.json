{
  "name": "@quentinadam/rlp",
  "version": "0.1.3",
  "description": "A simple library to encode data using the Recursive Length Prefix (RLP) encoding scheme, commonly used in Ethereum",
  "license": "MIT",
  "author": "Quentin Adam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quentinadam/deno-rlp.git"
  },
  "exports": "./src/rlp.ts",
  "imports": {
    "@quentinadam/assert": "jsr:@quentinadam/assert@^0.1.18",
    "@quentinadam/ensure": "jsr:@quentinadam/ensure@^0.1.6",
    "@quentinadam/uint8array-extension": "jsr:@quentinadam/uint8array-extension@^0.1.19",
    "typescript": "npm:typescript@^6.0.2"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 120
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true
  }
}
